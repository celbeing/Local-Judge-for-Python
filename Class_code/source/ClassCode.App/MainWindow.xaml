<Window x:Class="ClassCode.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="Class Code - Offline Judge" Height="720" Width="1280" 
        MinWidth="1000" MinHeight="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="White" Padding="5">
            <MenuItem Header="Open (_O)" FontSize="14" Padding="10,5">
                <MenuItem Header="문항 열기 (.zip)" Click="OpenProblem_Click" />
                <MenuItem Header="문제집 열기" Click="OpenWorkbook_Click" />
                <MenuItem Header="대회 열기" Click="OpenContest_Click" />
            </MenuItem>
            <MenuItem Header="Create (_C)" FontSize="14" Padding="10,5">
                <MenuItem Header="문항 만들기" Click="CreateProblem_Click" />
                <MenuItem Header="문제집 만들기" Click="CreateWorkbook_Click" />
                <MenuItem Header="대회 만들기" Click="CreateContest_Click" />
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="6*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="문항 정보" Grid.Column="0" Margin="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="5">
                        <TextBlock Text="1. 문제 상황" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                        <TextBlock Text="여기에 문제에 대한 자세한 설명을 입력하세요." TextWrapping="Wrap" Margin="0,0,0,20"/>
                        <TextBlock Text="2. 입력 조건" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                        <TextBlock Text="입력 형식 및 제한 사항을 입력하세요." TextWrapping="Wrap" Margin="0,0,0,20"/>
                        <TextBlock Text="3. 출력 조건" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                        <TextBlock Text="출력 형식을 입력하세요." TextWrapping="Wrap" Margin="0,0,0,20"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                <TextBlock Text="예제 입력" FontWeight="Bold" Margin="0,0,0,5"/>
                                <Border BorderBrush="LightGray" BorderThickness="1" Padding="5" Background="#F9F9F9">
                                    <TextBlock Text="1 2" FontFamily="Consolas"/>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="예제 출력" FontWeight="Bold" Margin="0,0,0,5"/>
                                <Border BorderBrush="LightGray" BorderThickness="1" Padding="5" Background="#F9F9F9">
                                    <TextBlock Text="3" FontFamily="Consolas"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#EEE"/>

            <Grid Grid.Column="2" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <GroupBox Header="Python Code Editor" Grid.Row="0">
                    <avalonEdit:TextEditor Name="codeEditor"
                               FontFamily="Consolas"
                               FontSize="14"
                               ShowLineNumbers="True"
                               Background="#F5F5F5"/>
                </GroupBox>

                <GridSplitter Grid.Row="1" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Background="#EEE"/>

                <TabControl Grid.Row="2" Margin="0,5,0,0">
                    <TabItem Header="실행 결과 (Terminal)">
                        <TextBox Background="Black" Foreground="White" 
                                 FontFamily="Consolas" 
                                 IsReadOnly="True" 
                                 Text=">_ 파이썬 코드를 실행하면 결과가 여기에 표시됩니다."/>
                    </TabItem>
                    <TabItem Header="채점 리포트">
                        <StackPanel Margin="10">
                            <TextBlock Text="상태: 대기 중" Margin="0,5"/>
                            <TextBlock Text="시간: 0ms" Margin="0,5"/>
                            <TextBlock Text="메모리: 0KB" Margin="0,5"/>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </Grid>
</Window>