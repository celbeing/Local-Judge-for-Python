<Window x:Class="ClassCode.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClassCode.App"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="1.5*" />
            </Grid.ColumnDefinitions>

            <GroupBox Header="문제 설명" Grid.Column="0" Margin="5">
                <TextBlock Text="여기에 문항 데이터가 표시됩니다." TextWrapping="Wrap" VerticalAlignment="Top"/>
            </GroupBox>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="LightGray"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="150" />
                </Grid.RowDefinitions>

                <GroupBox Header="Python Code Editor" Grid.Row="0" Margin="5">
                    <TextBox Text="print('Hello Class Code!')" AcceptsReturn="True" FontFamily="Consolas"/>
                </GroupBox>

                <GroupBox Header="채점 결과" Grid.Row="1" Margin="5">
                    <TextBlock Text="대기 중..." Foreground="Gray"/>
                </GroupBox>
            </Grid>
        </Grid>
    </Grid>
</Window>
