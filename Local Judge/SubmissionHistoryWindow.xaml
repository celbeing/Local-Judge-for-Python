<Window x:Class="Local_Judge.SubmissionHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="제출 이력"
        Height="680"
        Width="1000"
        MinHeight="560"
        MinWidth="860"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="8" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock x:Name="ProblemTitleTextBlock"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Text="제출 이력" />
                <TextBlock x:Name="SummaryTextBlock"
                           Margin="0,4,0,0"
                           Foreground="#57606A" />
            </StackPanel>
            <Button Content="닫기"
                    DockPanel.Dock="Right"
                    Width="74"
                    Height="28"
                    Click="CloseButton_Click" />
        </DockPanel>

        <Grid Grid.Row="1">
            <TextBlock x:Name="EmptyTextBlock"
                       Text="저장된 제출 이력이 없습니다."
                       Foreground="#57606A"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Collapsed" />
            <DataGrid x:Name="AttemptsDataGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionChanged="AttemptsDataGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="제출 시각" Binding="{Binding SubmittedAtText}" Width="170" />
                    <DataGridTextColumn Header="언어" Binding="{Binding Language}" Width="80" />
                    <DataGridTextColumn Header="결과" Binding="{Binding Verdict}" Width="80" />
                    <DataGridTextColumn Header="통과" Binding="{Binding PassedText}" Width="90" />
                    <DataGridTextColumn Header="최대 시간" Binding="{Binding MaxElapsedText}" Width="100" />
                    <DataGridTextColumn Header="최대 메모리" Binding="{Binding MaxMemoryText}" Width="110" />
                    <DataGridTextColumn Header="적용 제한" Binding="{Binding AppliedLimitsText}" Width="*" />
                    <DataGridTextColumn Header="파일" Binding="{Binding FileName}" Width="180" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <GridSplitter Grid.Row="2"
                      Height="8"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Background="#EAECEF"
                      Cursor="SizeNS" />

        <TabControl Grid.Row="3">
            <TabItem Header="코드">
                <TextBox x:Name="CodeTextBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         FontFamily="Consolas"
                         FontSize="13"
                         BorderThickness="0"
                         Padding="10"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap" />
            </TabItem>

            <TabItem Header="테스트 결과">
                <DataGrid x:Name="TestResultsDataGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding TestNumber}" Width="54" />
                        <DataGridTextColumn Header="결과" Binding="{Binding Verdict}" Width="90" />
                        <DataGridTextColumn Header="시간" Binding="{Binding ElapsedText}" Width="100" />
                        <DataGridTextColumn Header="메모리" Binding="{Binding MemoryText}" Width="110" />
                        <DataGridTextColumn Header="ExitCode" Binding="{Binding ExitCode}" Width="80" />
                        <DataGridTextColumn Header="stdout" Binding="{Binding OutputSummary}" Width="*" />
                        <DataGridTextColumn Header="stderr" Binding="{Binding ErrorSummary}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="저장 정보">
                <TextBox x:Name="DetailTextBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         FontFamily="Consolas"
                         FontSize="13"
                         BorderThickness="0"
                         Padding="10"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap" />
            </TabItem>
        </TabControl>
    </Grid>
</Window>
