<Window x:Class="Local_Judge.SubmissionHistoryFileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="제출 이력 파일 확인"
        Height="760"
        Width="1120"
        MinHeight="640"
        MinWidth="980"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="8" />
            <RowDefinition Height="3*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock x:Name="TitleTextBlock"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Text="제출 이력 파일" />
                <TextBlock x:Name="SummaryTextBlock"
                           Margin="0,4,0,0"
                           Foreground="#57606A" />
            </StackPanel>
            <Button Content="닫기"
                    DockPanel.Dock="Right"
                    Width="74"
                    Height="28"
                    Click="CloseButton_Click" />
        </DockPanel>

        <GroupBox x:Name="ContestSummaryGroupBox"
                  Grid.Row="1"
                  Header="대회 요약"
                  Margin="0,0,0,10"
                  Visibility="Collapsed">
            <DockPanel LastChildFill="True">
                <TextBlock x:Name="ContestSummaryTextBlock"
                           DockPanel.Dock="Top"
                           Margin="8"
                           FontWeight="SemiBold" />
                <DataGrid x:Name="ContestSummaryDataGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          MaxHeight="160">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="문항" Binding="{Binding ProblemName}" Width="*" />
                        <DataGridTextColumn Header="제출" Binding="{Binding AttemptCount}" Width="70" />
                        <DataGridTextColumn Header="첫 AC까지" Binding="{Binding FirstAcceptedAttemptText}" Width="90" />
                        <DataGridTextColumn Header="패널티" Binding="{Binding PenaltyText}" Width="90" />
                        <DataGridTextColumn Header="점수" Binding="{Binding Score}" Width="70" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="문항 요약">
            <DataGrid x:Name="ProblemSummaryDataGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionChanged="ProblemSummaryDataGrid_SelectionChanged">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="{Binding RowForeground}" />
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="번호" Binding="{Binding ProblemId}" Width="90" />
                    <DataGridTextColumn Header="제목" Binding="{Binding Title}" Width="*" />
                    <DataGridTextColumn Header="제한 시간" Binding="{Binding TimeLimitText}" Width="100" />
                    <DataGridTextColumn Header="제한 메모리" Binding="{Binding MemoryLimitText}" Width="110" />
                    <DataGridTextColumn Header="제출" Binding="{Binding AttemptCount}" Width="70" />
                    <DataGridTextColumn Header="첫 AC까지" Binding="{Binding FirstAcceptedAttemptText}" Width="90" />
                    <DataGridTextColumn Header="최고 결과" Binding="{Binding BestVerdict}" Width="90" />
                    <DataGridTextColumn Header="실행시간" Binding="{Binding MaxElapsedText}" Width="100" />
                    <DataGridTextColumn Header="메모리" Binding="{Binding MaxMemoryText}" Width="100" />
                    <DataGridTextColumn Header="점수" Binding="{Binding Score}" Width="70" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GridSplitter Grid.Row="3"
                      Height="8"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Background="#EAECEF"
                      Cursor="SizeNS" />

        <TabControl Grid.Row="4">
            <TabItem Header="제출 정보">
                <DataGrid x:Name="SubmissionsDataGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionChanged="SubmissionsDataGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="제출 시각" Binding="{Binding SubmittedAtText}" Width="170" />
                        <DataGridTextColumn Header="언어" Binding="{Binding Language}" Width="80" />
                        <DataGridTextColumn Header="결과" Binding="{Binding Verdict}" Width="90" />
                        <DataGridTextColumn Header="통과" Binding="{Binding PassedText}" Width="90" />
                        <DataGridTextColumn Header="실행시간" Binding="{Binding MaxElapsedText}" Width="100" />
                        <DataGridTextColumn Header="메모리" Binding="{Binding MaxMemoryText}" Width="100" />
                        <DataGridTextColumn Header="적용 제한" Binding="{Binding AppliedLimitsText}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="코드">
                <TextBox x:Name="CodeTextBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         FontFamily="Consolas"
                         FontSize="13"
                         BorderThickness="0"
                         Padding="10"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap" />
            </TabItem>

            <TabItem Header="테스트 결과">
                <DataGrid x:Name="TestResultsDataGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding TestNumber}" Width="54" />
                        <DataGridTextColumn Header="결과" Binding="{Binding Verdict}" Width="90" />
                        <DataGridTextColumn Header="시간" Binding="{Binding ElapsedText}" Width="100" />
                        <DataGridTextColumn Header="메모리" Binding="{Binding MemoryText}" Width="110" />
                        <DataGridTextColumn Header="ExitCode" Binding="{Binding ExitCode}" Width="80" />
                        <DataGridTextColumn Header="stdout" Binding="{Binding OutputSummary}" Width="*" />
                        <DataGridTextColumn Header="stderr" Binding="{Binding ErrorSummary}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
