<Window x:Class="Local_Judge.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="정보"
        Height="280"
        Width="520"
        MinHeight="260"
        MinWidth="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Local Judge"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Margin="0,0,0,4" />

        <TextBlock Grid.Row="1"
                   Text="C# WPF 기반 PS 로컬 저지 프로그램"
                   Foreground="#57606A"
                   Margin="0,0,0,20" />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="버전"
                       FontWeight="SemiBold"
                       Foreground="#57606A"
                       Margin="0,0,16,10" />
            <TextBlock x:Name="VersionTextBlock"
                       Grid.Row="0"
                       Grid.Column="1"
                       Margin="0,0,0,10" />

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Text="제작자"
                       FontWeight="SemiBold"
                       Foreground="#57606A"
                       Margin="0,0,16,10" />
            <TextBlock x:Name="AuthorTextBlock"
                       Grid.Row="1"
                       Grid.Column="1"
                       Margin="0,0,0,10" />

            <TextBlock Grid.Row="2"
                       Grid.Column="0"
                       Text="indischool ID"
                       FontWeight="SemiBold"
                       Foreground="#57606A"
                       Margin="0,0,16,10" />
            <TextBlock x:Name="IndischoolTextBlock"
                       Grid.Row="2"
                       Grid.Column="1"
                       Margin="0,0,0,10" />

            <TextBlock Grid.Row="3"
                       Grid.Column="0"
                       Text="tistory"
                       FontWeight="SemiBold"
                       Foreground="#57606A"
                       Margin="0,0,16,0" />
            <TextBlock x:Name="TistoryTextBlock"
                       Grid.Row="3"
                       Grid.Column="1"
                       TextWrapping="Wrap" />
        </Grid>

        <Button Grid.Row="3"
                Content="확인"
                Width="88"
                Height="30"
                HorizontalAlignment="Right"
                IsDefault="True"
                IsCancel="True"
                Click="OkButton_Click" />
    </Grid>
</Window>
