<Window x:Class="Local_Judge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Local_Judge"
        mc:Ignorable="d"
        Title="Local Judge"
        Height="800"
        Width="1200"
        MinHeight="650"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D0D7DE" />
        <SolidColorBrush x:Key="PanelHeaderBrush" Color="#F6F8FA" />
        <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#1E1E1E" />
        <SolidColorBrush x:Key="EditorForegroundBrush" Color="#D4D4D4" />
        <SolidColorBrush x:Key="TerminalBackgroundBrush" Color="#0C0C0C" />
        <SolidColorBrush x:Key="TerminalForegroundBrush" Color="#EAEAEA" />

        <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,18,0,8" />
        </Style>

        <Style x:Key="ReadOnlyProblemTextBoxStyle" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="SampleBoxStyle" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="AcceptsTab" Value="True" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Background" Value="#F6F8FA" />
            <Setter Property="BorderBrush" Value="#D0D7DE" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="MinHeight" Value="72" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- 상단 메뉴바 -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_파일">
                <MenuItem Header="새 문제 만들기..." Click="NewProblemMenuItem_Click" />
                <MenuItem x:Name="EditProblemMenuItem"
                          Header="문제 수정..."
                          Click="EditProblemMenuItem_Click" />
                <MenuItem Header="문제 불러오기..." Click="LoadProblemMenuItem_Click" />
                <MenuItem Header="문제 저장" Click="SaveProblemMenuItem_Click" />
                <MenuItem Header="다른 이름으로 문제 저장..." Click="SaveProblemAsMenuItem_Click" />
                <Separator />
                <MenuItem Header="코드 저장" Click="SaveCodeMenuItem_Click" />
                <Separator />
                <MenuItem Header="종료" Click="ExitMenuItem_Click" />
            </MenuItem>

            <MenuItem Header="_실행">
                <MenuItem x:Name="RunCodeMenuItem"
                          Header="실행"
                          Click="RunCodeMenuItem_Click" />
                <MenuItem x:Name="RunSampleMenuItem"
                          Header="예제 실행"
                          Click="RunSampleMenuItem_Click" />
                <MenuItem Header="디버그 시작" Click="DebugMenuItem_Click" />
            </MenuItem>

            <MenuItem Header="_저지">
                <MenuItem x:Name="SubmitMenuItem"
                          Header="제출"
                          Click="SubmitMenuItem_Click" />
                <MenuItem x:Name="SubmissionHistoryMenuItem"
                          Header="제출 이력 보기..."
                          Click="SubmissionHistoryMenuItem_Click" />
                <MenuItem x:Name="ExportSubmissionHistoryMenuItem"
                          Header="제출 이력 내보내기..."
                          Click="ExportSubmissionHistoryMenuItem_Click" />
                <MenuItem Header="제출 이력 파일 확인하기..."
                          Click="InspectSubmissionHistoryFileMenuItem_Click" />
            </MenuItem>

            <MenuItem Header="_도구">
                <MenuItem Header="Python 경로 설정" Click="PythonPathMenuItem_Click" />
                <MenuItem x:Name="BenchmarkMenuItem"
                          Header="채점 환경 벤치마크 다시 실행"
                          Click="BenchmarkMenuItem_Click" />
                <MenuItem Header="환경 설정" Click="SettingsMenuItem_Click" />
            </MenuItem>

            <MenuItem Header="_도움말">
                <MenuItem Header="정보" Click="AboutMenuItem_Click" />
            </MenuItem>
        </Menu>

        <!-- 최하단 상태 표시줄 -->
        <StatusBar DockPanel.Dock="Bottom" Height="28">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusIndicator"
                             Width="9"
                             Height="9"
                             Fill="#2DA44E"
                             Margin="0,0,8,0" />
                    <TextBlock Text="상태: " FontWeight="SemiBold" />
                    <TextBlock x:Name="StatusTextBlock" Text="채점 대기" />
                </StackPanel>
            </StatusBarItem>

            <Separator />

            <StatusBarItem>
                <TextBlock x:Name="CurrentProblemStatusTextBlock" Text="문제 미선택" />
            </StatusBarItem>
        </StatusBar>

        <!-- 메인 영역: 좌측 문제 / 우측 에디터 + 터미널 -->
        <Grid Background="#FFFFFF">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" MinWidth="300" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" MinWidth="450" />
            </Grid.ColumnDefinitions>

            <!-- 왼쪽 문제 설명 패널 -->
            <Border Grid.Column="0"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="0,0,1,0"
                    Background="#FFFFFF">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Background="{StaticResource PanelHeaderBrush}">
                        <DockPanel Margin="12,0" LastChildFill="False">
                            <TextBlock Text="문제"
                                       FontWeight="SemiBold"
                                       FontSize="15"
                                       VerticalAlignment="Center" />
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button Content="새 문제"
                                        Width="70"
                                        Height="26"
                                        Margin="0,0,6,0"
                                        Click="NewProblemMenuItem_Click" />
                                <Button x:Name="EditProblemButton"
                                        Content="수정"
                                        Width="58"
                                        Height="26"
                                        Margin="0,0,6,0"
                                        Click="EditProblemMenuItem_Click" />
                                <Button Content="불러오기"
                                        Width="78"
                                        Height="26"
                                        Click="LoadProblemMenuItem_Click" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <wv2:WebView2 x:Name="ProblemViewerWebView"
                                  Grid.Row="1"
                                  DefaultBackgroundColor="White" />
                </Grid>
            </Border>

            <!-- 좌우 크기 조절 스플리터 -->
            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#EAECEF"
                          Cursor="SizeWE"
                          ShowsPreview="True"
                          ToolTip="좌우 패널 크기 조정" />

            <!-- 오른쪽 코드 편집기 + 터미널 패널 -->
            <Grid Grid.Column="2" Background="#FFFFFF">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="260" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="210" MinHeight="120" />
                </Grid.RowDefinitions>

                <!-- 코드 편집기 -->
                <Border Grid.Row="0"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="44" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                BorderBrush="{StaticResource PanelBorderBrush}"
                                BorderThickness="0,0,0,1"
                                Background="{StaticResource PanelHeaderBrush}">
                            <DockPanel Margin="12,0" LastChildFill="False">
                                <TextBlock Text="Python 코드 편집기"
                                           FontWeight="SemiBold"
                                           FontSize="15"
                                           VerticalAlignment="Center" />

                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button x:Name="RunCodeButton"
                                            Content="실행"
                                            Width="70"
                                            Height="26"
                                            Margin="0,0,6,0"
                                            Click="RunCodeMenuItem_Click" />
                                    <Button x:Name="RunSampleButton"
                                            Content="예제 실행"
                                            Width="86"
                                            Height="26"
                                            Margin="0,0,6,0"
                                            Click="RunSampleMenuItem_Click" />
                                    <Button x:Name="SubmitButton"
                                            Content="제출"
                                            Width="70"
                                            Height="26"
                                            Click="SubmitMenuItem_Click" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <wv2:WebView2 x:Name="CodeEditorWebView"
                                      Grid.Row="1"
                                      DefaultBackgroundColor="#1E1E1E" />
                    </Grid>
                </Border>

                <!-- 상하 크기 조절 스플리터 -->
                <GridSplitter Grid.Row="1"
                              Height="6"
                              HorizontalAlignment="Stretch"
                              Background="#EAECEF"
                              Cursor="SizeNS"
                              ShowsPreview="True" />

                <!-- 실행 입력 / 터미널 탭 패널 -->
                <Border Grid.Row="2"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Background="#FFFFFF">
                    <TabControl x:Name="RunTabControl"
                                Background="#FFFFFF"
                                BorderThickness="0">
                        <TabItem x:Name="InputTabItem" Header="입력">
                            <Grid Background="#FFFFFF">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="36" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0"
                                           LastChildFill="True"
                                           Background="{StaticResource PanelHeaderBrush}">
                                    <TextBlock Text="프로그램 입력"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="12,0" />
                                    <TextBlock Text="실행 전에 stdin으로 보낼 입력을 작성하세요."
                                               Foreground="#57606A"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0" />
                                </DockPanel>

                                <TextBox x:Name="ProgramInputTextBox"
                                         Grid.Row="1"
                                         AcceptsReturn="True"
                                         AcceptsTab="True"
                                         FontFamily="Consolas"
                                         FontSize="13"
                                         Background="#0D1117"
                                         Foreground="#EAEAEA"
                                         CaretBrush="#EAEAEA"
                                         BorderThickness="0"
                                         Padding="12"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         TextWrapping="NoWrap"
                                         SpellCheck.IsEnabled="False" />
                            </Grid>
                        </TabItem>

                        <TabItem x:Name="TerminalTabItem" Header="터미널">
                            <Grid Background="{StaticResource TerminalBackgroundBrush}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="36" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0"
                                           LastChildFill="False"
                                           Background="#161B22">
                                    <TextBlock Text="터미널 / 실행 결과"
                                               Foreground="#FFFFFF"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="12,0" />

                                    <Button Content="지우기"
                                            DockPanel.Dock="Right"
                                            Width="70"
                                            Height="24"
                                            Margin="0,0,10,0"
                                            Click="ClearTerminalMenuItem_Click" />

                                    <Button x:Name="StopRunButton"
                                            Content="중지"
                                            DockPanel.Dock="Right"
                                            Width="58"
                                            Height="24"
                                            Margin="0,0,6,0"
                                            IsEnabled="False"
                                            Click="StopRunButton_Click" />
                                </DockPanel>

                                <RichTextBox x:Name="TerminalTextBox"
                                             Grid.Row="1"
                                             IsReadOnly="True"
                                             FontFamily="Consolas"
                                             FontSize="13"
                                             Background="{StaticResource TerminalBackgroundBrush}"
                                             Foreground="{StaticResource TerminalForegroundBrush}"
                                             BorderThickness="0"
                                             Padding="12"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto">
                                    <FlowDocument PagePadding="0">
                                        <Paragraph Margin="0">
                                            <Run Text="[System] Local Judge가 시작되었습니다." />
                                            <LineBreak />
                                        </Paragraph>
                                    </FlowDocument>
                                </RichTextBox>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
