<Window x:Class="Local_Judge.ContestCreatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="대회 만들기"
        Width="960"
        Height="720"
        MinWidth="820"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D0D7DE" />
        <SolidColorBrush x:Key="PanelHeaderBrush" Color="#F6F8FA" />

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,12,8" />
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="ComboInputStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <DockPanel Background="#FFFFFF" LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Height="52"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="0,0,0,1"
                Background="{StaticResource PanelHeaderBrush}">
            <DockPanel Margin="18,0">
                <TextBlock Text="대회 정보 입력"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <TextBlock Text="문제 JSON과 assets 폴더를 묶어 배포용 대회 ZIP을 만듭니다."
                           DockPanel.Dock="Right"
                           Foreground="#57606A"
                           VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <Border DockPanel.Dock="Bottom"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="0,1,0,0"
                Background="{StaticResource PanelHeaderBrush}"
                Padding="12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="취소"
                        Width="90"
                        Height="30"
                        Margin="0,0,8,0"
                        IsCancel="True" />
                <Button Content="저장"
                        Width="90"
                        Height="30"
                        IsDefault="True"
                        Click="SaveButton_Click" />
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="18">
                <GroupBox Header="대회 정보" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="대회명" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="TitleTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource InputTextBoxStyle}" />
                        </Grid>

                        <DockPanel LastChildFill="False" Margin="0,2,0,8">
                            <TextBlock Text="추가 정보"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       DockPanel.Dock="Left" />
                            <Button Content="정보 추가"
                                    Width="90"
                                    Height="28"
                                    Margin="12,0,0,0"
                                    DockPanel.Dock="Left"
                                    Click="AddContestInfoButton_Click" />
                        </DockPanel>

                        <ItemsControl ItemsSource="{Binding ContestInfoItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="72" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox Grid.Column="0"
                                                 Text="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="30"
                                                 Margin="0,0,8,0"
                                                 Padding="8,4"
                                                 VerticalContentAlignment="Center"
                                                 ToolTip="라벨 예: 장소, 주최, 상품" />
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="30"
                                                 Margin="0,0,8,0"
                                                 Padding="8,4"
                                                 VerticalContentAlignment="Center"
                                                 ToolTip="설명" />
                                        <Button Grid.Column="2"
                                                Content="삭제"
                                                Height="30"
                                                Tag="{Binding}"
                                                Click="RemoveContestInfoButton_Click" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="대회명은 필수입니다. 장소, 주최, 상품처럼 필요한 안내 항목은 정보 추가로 직접 만들 수 있습니다."
                                   Foreground="#57606A"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="대회 시간" Padding="12" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="68" />
                            <ColumnDefinition Width="68" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="시작" Style="{StaticResource FieldLabelStyle}" />
                        <DatePicker x:Name="StartDatePicker"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Height="30"
                                    Margin="0,0,8,8" />
                        <ComboBox x:Name="StartHourComboBox"
                                  Grid.Row="0"
                                  Grid.Column="2"
                                  ItemsSource="{Binding HourOptions}"
                                  DisplayMemberPath="Text"
                                  SelectedValuePath="Value"
                                  Style="{StaticResource ComboInputStyle}" />
                        <ComboBox x:Name="StartMinuteComboBox"
                                  Grid.Row="0"
                                  Grid.Column="3"
                                  ItemsSource="{Binding MinuteOptions}"
                                  DisplayMemberPath="Text"
                                  SelectedValuePath="Value"
                                  Style="{StaticResource ComboInputStyle}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="종료" Style="{StaticResource FieldLabelStyle}" />
                        <DatePicker x:Name="EndDatePicker"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Height="30"
                                    Margin="0,0,8,8" />
                        <ComboBox x:Name="EndHourComboBox"
                                  Grid.Row="1"
                                  Grid.Column="2"
                                  ItemsSource="{Binding HourOptions}"
                                  DisplayMemberPath="Text"
                                  SelectedValuePath="Value"
                                  Style="{StaticResource ComboInputStyle}" />
                        <ComboBox x:Name="EndMinuteComboBox"
                                  Grid.Row="1"
                                  Grid.Column="3"
                                  ItemsSource="{Binding MinuteOptions}"
                                  DisplayMemberPath="Text"
                                  SelectedValuePath="Value"
                                  Style="{StaticResource ComboInputStyle}" />

                        <TextBlock Grid.Row="0"
                                   Grid.RowSpan="2"
                                   Grid.Column="4"
                                   Text="시와 분을 따로 선택합니다. 분은 5분 단위입니다."
                                   Foreground="#57606A"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="12,0,0,8" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="문항" Padding="12">
                    <DockPanel LastChildFill="True" MinHeight="300">
                        <StackPanel DockPanel.Dock="Top"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,8">
                            <Button Content="문항 추가..."
                                    Width="100"
                                    Height="30"
                                    Margin="0,0,8,0"
                                    Click="AddProblemButton_Click" />
                            <Button Content="삭제"
                                    Width="70"
                                    Height="30"
                                    Margin="0,0,8,0"
                                    Click="RemoveProblemButton_Click" />
                            <Button Content="위로"
                                    Width="70"
                                    Height="30"
                                    Margin="0,0,8,0"
                                    Click="MoveProblemUpButton_Click" />
                            <Button Content="아래로"
                                    Width="70"
                                    Height="30"
                                    Margin="0,0,18,0"
                                    Click="MoveProblemDownButton_Click" />
                            <TextBlock x:Name="ProblemCountTextBlock"
                                       Text="문항 0개"
                                       Foreground="#57606A"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <DataGrid x:Name="ProblemDataGrid"
                                  ItemsSource="{Binding ContestProblems}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  SelectionMode="Single"
                                  MinHeight="230"
                                  MaxHeight="340">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="라벨"
                                                    Binding="{Binding Label}"
                                                    IsReadOnly="True"
                                                    Width="64" />
                                <DataGridTextColumn Header="제목"
                                                    Binding="{Binding DisplayName}"
                                                    IsReadOnly="True"
                                                    Width="220" />
                                <DataGridTemplateColumn Header="풍선 색"
                                                        Width="150">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding DataContext.BalloonColorOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      SelectedValuePath="Hex"
                                                      SelectedValue="{Binding BalloonColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Height="26"
                                                      Margin="0,2">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Width="14"
                                                                    Height="14"
                                                                    Margin="0,0,6,0"
                                                                    Background="{Binding Brush}"
                                                                    BorderBrush="#57606A"
                                                                    BorderThickness="1" />
                                                            <TextBlock Text="{Binding Name}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="원본 파일"
                                                    Binding="{Binding SourceFilePath}"
                                                    IsReadOnly="True"
                                                    Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
