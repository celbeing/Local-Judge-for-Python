<Window x:Class="Local_Judge.ContestPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="대회 암호 입력"
        Width="380"
        Height="190"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">
    <DockPanel Background="#FFFFFF" LastChildFill="True">
        <Border DockPanel.Dock="Bottom"
                BorderBrush="#D0D7DE"
                BorderThickness="0,1,0,0"
                Background="#F6F8FA"
                Padding="12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="취소"
                        Width="80"
                        Height="30"
                        Margin="0,0,8,0"
                        IsCancel="True" />
                <Button Content="확인"
                        Width="80"
                        Height="30"
                        IsDefault="True"
                        Click="OkButton_Click" />
            </StackPanel>
        </Border>

        <StackPanel Margin="18">
            <TextBlock Text="대회 채점 테스트케이스 암호"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />
            <PasswordBox x:Name="ContestPasswordBox"
                         Height="30"
                         Padding="8,4"
                         VerticalContentAlignment="Center" />
            <TextBlock Text="대회 생성 시 설정한 4자리 숫자 암호입니다. 암호가 맞지 않아도 대회는 열리지만 제출 채점은 진행할 수 없습니다."
                       Foreground="#57606A"
                       TextWrapping="Wrap"
                       Margin="0,10,0,0" />
        </StackPanel>
    </DockPanel>
</Window>
