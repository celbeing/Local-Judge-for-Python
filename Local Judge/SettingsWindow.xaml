<Window x:Class="Local_Judge.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="환경 설정"
        Height="350"
        Width="660"
        MinHeight="330"
        MinWidth="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        FontFamily="Segoe UI">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="저장 위치"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,14" />

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="96" />
                <ColumnDefinition Width="72" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="문항 저장 경로"
                       VerticalAlignment="Center"
                       Margin="0,0,12,10" />
            <TextBox x:Name="ProblemSaveDirectoryTextBox"
                     Grid.Row="0"
                     Grid.Column="1"
                     Height="28"
                     Margin="0,0,8,10"
                     VerticalContentAlignment="Center" />
            <Button Grid.Row="0"
                    Grid.Column="2"
                    Content="찾아보기..."
                    Height="28"
                    Margin="0,0,8,10"
                    Click="BrowseProblemSaveDirectoryButton_Click" />
            <Button Grid.Row="0"
                    Grid.Column="3"
                    Content="비우기"
                    Height="28"
                    Margin="0,0,0,10"
                    Click="ClearProblemSaveDirectoryButton_Click" />

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Text="제출 이력 내보내기"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0" />
            <TextBox x:Name="SubmissionHistoryExportDirectoryTextBox"
                     Grid.Row="1"
                     Grid.Column="1"
                     Height="28"
                     Margin="0,0,8,0"
                     VerticalContentAlignment="Center" />
            <Button Grid.Row="1"
                    Grid.Column="2"
                    Content="찾아보기..."
                    Height="28"
                    Margin="0,0,8,0"
                    Click="BrowseSubmissionHistoryExportDirectoryButton_Click" />
            <Button Grid.Row="1"
                    Grid.Column="3"
                    Content="비우기"
                    Height="28"
                    Click="ClearSubmissionHistoryExportDirectoryButton_Click" />
        </Grid>

        <GroupBox Grid.Row="2"
                  Header="자동 저장"
                  Margin="0,18,0,0"
                  Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <CheckBox x:Name="AutoSaveDraftsCheckBox"
                          Grid.Row="0"
                          Grid.ColumnSpan="4"
                          Content="수업/대회 문항 코드 draft 자동 저장"
                          VerticalAlignment="Center"
                          Checked="AutoSaveDraftsCheckBox_Changed"
                          Unchecked="AutoSaveDraftsCheckBox_Changed" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Text="자동 저장 주기"
                           VerticalAlignment="Center"
                           Margin="0,12,12,0" />
                <TextBox x:Name="AutoSaveIntervalTextBox"
                         Grid.Row="1"
                         Grid.Column="1"
                         Width="86"
                         Height="28"
                         Margin="0,12,8,0"
                         VerticalContentAlignment="Center" />
                <TextBlock x:Name="AutoSaveIntervalUnitTextBlock"
                           Grid.Row="1"
                           Grid.Column="2"
                           Text="초"
                           VerticalAlignment="Center"
                           Margin="0,12,12,0" />
                <TextBlock x:Name="AutoSaveIntervalHelpTextBlock"
                           Grid.Row="1"
                           Grid.Column="3"
                           Text="5초부터 3600초까지 설정할 수 있습니다."
                           Foreground="#57606A"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,12,0,0" />
            </Grid>
        </GroupBox>

        <TextBlock Grid.Row="3"
                   Text="비워 두면 Windows가 마지막으로 사용한 위치를 기준으로 저장 대상을 엽니다. 자동 저장 draft는 수업/대회 문항 코드에만 적용됩니다."
                   Foreground="#57606A"
                   TextWrapping="Wrap"
                   Margin="0,14,0,0" />

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="확인"
                    Width="84"
                    Height="30"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OkButton_Click" />
            <Button Content="취소"
                    Width="84"
                    Height="30"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
