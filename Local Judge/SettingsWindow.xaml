<Window x:Class="Local_Judge.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="환경 설정"
        Height="260"
        Width="620"
        MinHeight="240"
        MinWidth="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        FontFamily="Segoe UI">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="저장 위치"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,14" />

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="92" />
                <ColumnDefinition Width="70" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="문항 저장 경로"
                       VerticalAlignment="Center"
                       Margin="0,0,12,10" />
            <TextBox x:Name="ProblemSaveDirectoryTextBox"
                     Grid.Row="0"
                     Grid.Column="1"
                     Height="28"
                     Margin="0,0,8,10"
                     VerticalContentAlignment="Center" />
            <Button Grid.Row="0"
                    Grid.Column="2"
                    Content="찾아보기..."
                    Height="28"
                    Margin="0,0,8,10"
                    Click="BrowseProblemSaveDirectoryButton_Click" />
            <Button Grid.Row="0"
                    Grid.Column="3"
                    Content="비우기"
                    Height="28"
                    Margin="0,0,0,10"
                    Click="ClearProblemSaveDirectoryButton_Click" />

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       Text="제출 이력 내보내기"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0" />
            <TextBox x:Name="SubmissionHistoryExportDirectoryTextBox"
                     Grid.Row="1"
                     Grid.Column="1"
                     Height="28"
                     Margin="0,0,8,0"
                     VerticalContentAlignment="Center" />
            <Button Grid.Row="1"
                    Grid.Column="2"
                    Content="찾아보기..."
                    Height="28"
                    Margin="0,0,8,0"
                    Click="BrowseSubmissionHistoryExportDirectoryButton_Click" />
            <Button Grid.Row="1"
                    Grid.Column="3"
                    Content="비우기"
                    Height="28"
                    Click="ClearSubmissionHistoryExportDirectoryButton_Click" />
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="비워 두면 Windows가 마지막으로 사용한 위치를 기준으로 저장 대화상자를 엽니다."
                   Foreground="#57606A"
                   TextWrapping="Wrap"
                   Margin="0,14,0,0" />

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="확인"
                    Width="84"
                    Height="30"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="OkButton_Click" />
            <Button Content="취소"
                    Width="84"
                    Height="30"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
